{
  "$schema": "https://schemas.dtcg.io/tokens/0.0.1/schema.json",
  "$description": "MLB Value Bets — design tokens. Canonical web values from frontend/src/index.css. W3C DTCG format; import into Figma via the Variables plugin.",

  "color": {
    "navy": {
      "deep":    { "$value": "#060D1A", "$type": "color", "$description": "Primary background. Darkest navy. Used as body fill behind everything." },
      "mid":     { "$value": "#0A1628", "$type": "color", "$description": "Section strip, subtle elevation above background." },
      "card":    { "$value": "#0D1F38", "$type": "color", "$description": "Card fill. One step up from background." },
      "border":  { "$value": "#162840", "$type": "color", "$description": "Hairline border on cards and dividers." },
      "hover":   { "$value": "#1A2E4A", "$type": "color", "$description": "Hover/press highlight, one step brighter than card." }
    },
    "blue": {
      "DEFAULT": { "$value": "#1E6FFF", "$type": "color", "$description": "Primary CTA + focus ring + radial light source." },
      "dim":     { "$value": "#1558CC", "$type": "color", "$description": "Pressed-state darker blue." },
      "glow":    { "$value": "rgba(30, 111, 255, 0.18)", "$type": "color", "$description": "Alpha blue used for radial glows and outer shadows." }
    },
    "amber": {
      "DEFAULT": { "$value": "#F5A623", "$type": "color", "$description": "PRO tier + Sharp signal + secondary accent." },
      "dim":     { "$value": "#C4841B", "$type": "color" },
      "glow":    { "$value": "rgba(245, 166, 35, 0.15)", "$type": "color" }
    },
    "outcome": {
      "win":  { "$value": "#22C55E", "$type": "color" },
      "loss": { "$value": "#EF4444", "$type": "color" },
      "push": { "$value": "rgba(255, 255, 255, 0.40)", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "#FFFFFF",                     "$type": "color" },
      "secondary": { "$value": "rgba(255, 255, 255, 0.60)",   "$type": "color" },
      "muted":     { "$value": "rgba(255, 255, 255, 0.40)",   "$type": "color" },
      "faint":     { "$value": "rgba(255, 255, 255, 0.25)",   "$type": "color" }
    }
  },

  "font": {
    "family": {
      "display": { "$value": "Bebas Neue",   "$type": "fontFamily", "$description": "Big poster/display numerals. Single weight, condensed caps." },
      "ui":      { "$value": "Barlow",       "$type": "fontFamily", "$description": "Body text, buttons, labels." },
      "data":    { "$value": "IBM Plex Mono","$type": "fontFamily", "$description": "Tabular numerals — odds, EV, ROI alignment." }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xs":      { "$value": "11px", "$type": "dimension" },
      "sm":      { "$value": "13px", "$type": "dimension" },
      "base":    { "$value": "15px", "$type": "dimension" },
      "lg":      { "$value": "18px", "$type": "dimension" },
      "xl":      { "$value": "24px", "$type": "dimension" },
      "display": { "$value": "48px", "$type": "dimension" },
      "hero":    { "$value": "72px", "$type": "dimension" }
    }
  },

  "spacing": {
    "xxs":  { "$value": "2px",  "$type": "dimension" },
    "xs":   { "$value": "4px",  "$type": "dimension" },
    "sm":   { "$value": "8px",  "$type": "dimension" },
    "md":   { "$value": "12px", "$type": "dimension" },
    "lg":   { "$value": "16px", "$type": "dimension" },
    "xl":   { "$value": "24px", "$type": "dimension" },
    "xxl":  { "$value": "32px", "$type": "dimension" },
    "xxxl": { "$value": "48px", "$type": "dimension" }
  },

  "radius": {
    "sm": { "$value": "8px",  "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "20px", "$type": "dimension" }
  },

  "border": {
    "width": {
      "hairline": { "$value": "0.5px", "$type": "dimension" },
      "thin":     { "$value": "1px",   "$type": "dimension" },
      "thick":    { "$value": "2px",   "$type": "dimension" }
    }
  },

  "motion": {
    "curve": {
      "reveal":   { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier", "$description": "Web 'draw' curve used for fadeUp animation." },
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",   "$type": "cubicBezier" }
    },
    "duration": {
      "tap":    { "$value": "200ms",  "$type": "duration" },
      "spring": { "$value": "350ms",  "$type": "duration" },
      "reveal": { "$value": "650ms",  "$type": "duration" },
      "glow":   { "$value": "1600ms", "$type": "duration", "$description": "Synced with CountUp animation on the web." }
    }
  },

  "background": {
    "atmosphere": {
      "blueGlowAlpha":   { "$value": 0.20, "$type": "number", "$description": "Top-center radial blue glow at UnitPoint(0.5, -0.05)." },
      "amberGlowAlpha":  { "$value": 0.08, "$type": "number", "$description": "Bottom-right radial amber glow at UnitPoint(0.85, 0.90)." },
      "gridAlpha":       { "$value": 0.06, "$type": "number", "$description": "44pt blueprint grid lines in brand-blue." },
      "gridStep":        { "$value": "44px", "$type": "dimension" }
    }
  }
}
